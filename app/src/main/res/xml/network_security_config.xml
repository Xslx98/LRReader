<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ LANraragi Reader - Network Security Configuration
  ~ Allows cleartext HTTP for LAN IP access and user-installed certificates for self-signed HTTPS.
  -->

<network-security-config>
    <!-- Allow cleartext (HTTP) globally for LAN IP access (e.g., http://192.168.x.x:3000) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
