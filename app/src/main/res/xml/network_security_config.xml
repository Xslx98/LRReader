<?xml version="1.0" encoding="utf-8"?>
<!--
  LANraragi Reader — Network Security Configuration

  LANraragi is a self-hosted server typically running on a LAN over plain HTTP.
  Android's <domain-config> cannot match IP ranges (CIDR), so we must allow
  cleartext globally for the base-config. The LRRAuthInterceptor ensures that
  the API key is only sent to the configured server host, mitigating the risk
  of credential leakage over unencrypted connections to other hosts.

  User-installed CAs are trusted so self-signed HTTPS setups (e.g., reverse
  proxy with a private CA) work without extra configuration.
-->
<network-security-config>

    <!--
      Allow cleartext for all hosts: LANraragi servers are commonly accessed
      via bare LAN IP (e.g., 192.168.x.x:3000) over HTTP. Android's
      network_security_config has no CIDR/wildcard-IP support, so a blanket
      allowance is the only way to support arbitrary LAN addresses.

      User-installed CAs are NOT trusted in release builds to prevent MITM
      attacks via rogue CAs. Users with self-signed HTTPS setups should
      import the CA into the system trust store or use the debug build.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Debug builds only: trust user CA for all hosts (Charles, mitmproxy, etc.) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>

</network-security-config>
