<?xml version="1.0" encoding="utf-8"?>
<!--
  LANraragi Reader — Network Security Configuration

  WHY CLEARTEXT IS GLOBALLY ALLOWED HERE:

  LANraragi servers are typically reached via bare LAN IPs over plain HTTP
  (e.g., http://192.168.1.23:3000). Android's <domain-config> cannot match
  CIDR ranges or wildcard IPs, and we do not know which IP a given user has
  configured at install time. We therefore must allow cleartext at the OS
  level for ALL hosts.

  WHERE THE REAL CLEARTEXT POLICY LIVES:

  The authoritative cleartext gate is `LRRCleartextRejectionInterceptor`
  (see app/src/main/java/com/hippo/ehviewer/client/lrr/). It throws
  LRRCleartextRefusedException for any HTTP request that is NOT directed
  at the currently-configured active LANraragi server, AND additionally
  requires that profile's `allowCleartext` flag to be true (per-profile
  user opt-in via the ServerListScene add/edit dialog).

  Net effect at runtime: cleartext only goes out to one specific host,
  and only when the user explicitly ticked "trust this server over plain
  HTTP" when they created or edited the profile.

  TRUST ANCHORS (release vs debug):
    base-config       → system CAs only
    debug-overrides   → system + user CAs (Charles, mitmproxy, etc.)

  Release builds do NOT trust user-installed CAs. If you need to point a
  release build at a self-signed HTTPS LANraragi server, install the CA
  via the system trust store. (A future branch — `security/server-ca-import`
  — will add an in-app CA import flow.)
-->
<network-security-config>

    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>

</network-security-config>
